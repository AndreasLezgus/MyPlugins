{
  "mcpServers": {
    "devonthink": {
      "command": "npx",
      "args": [
        "-y",
        "github:TomBener/devonthink-mcp"
      ]
    },
    "noteplan": {
      "command": "node",
      "args": [
        "${HOME}/noteplan-mcp/dist/index.js"
      ],
      "env": {
        "NOTEPLAN_BASE_PATH": "${HOME}/Library/Containers/co.noteplan.NotePlan-setapp/Data/Library/Application Support/co.noteplan.NotePlan-setapp"
      }
    },
    "ulysses": {
      "command": "${HOME}/.local/bin/uv",
      "args": [
        "--directory",
        "${HOME}/ulysses-mcp",
        "run",
        "ulysses-mcp"
      ]
    }
  }
}
