{
  "mcpServers": {
    "devonthink": {
      "command": "npx",
      "args": [
        "-y",
        "github:TomBener/devonthink-mcp"
      ]
    },
      "noteplan": {
      "command": "npx",
      "args": ["-y", "@noteplanco/noteplan-mcp"]
    },

      "ulysses": {
      "command": "${HOME}/.local/bin/uv",
      "args": [
        "--directory",
        "${HOME}/ulysses-mcp",
        "run",
        "ulysses-mcp"
      ]
    }
  }
}
