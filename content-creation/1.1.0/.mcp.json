{
  "mcpServers": {
    "devonthink": {
      "command": "npx",
      "args": [
        "-y",
        "github:TomBener/devonthink-mcp"
      ]
    },
    "noteplan": {
      "command": "node",
      "args": [
        "/Users/administrator/noteplan-mcp/dist/index.js"
      ],
      "env": {
        "NOTEPLAN_BASE_PATH": "/Users/andreas/Library/Containers/co.noteplan.NotePlan-setapp/Data/Library/Application Support/co.noteplan.NotePlan-setapp"
      }
    },
    "ulysses": {
  "command": "/Users/andreas/.local/bin/uv",
  "args": [
    "--directory",
    "/Users/andreas/ulysses-mcp",
    "run",
    "ulysses-mcp"
  ]
},
    "drafts": {
      "command": "npx",
      "args": [
        "@agiletortoise/drafts-mcp-server"
      ]
    }
  },
  "preferences": {
    "localAgentModeTrustedFolders": [
      "/Users/andreas/Library/Mobile Documents/com~apple~CloudDocs/10-Code/99-Archiv/01-Claude-Code/01-Settings"
    ],
    "sidebarMode": "chat",
    "coworkScheduledTasksEnabled": false
  }
}
